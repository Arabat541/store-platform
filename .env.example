# Store Platform - Environment Variables

# Database
DATABASE_URL="mysql://user:password@localhost:3306/store_platform"

# JWT
JWT_SECRET="change-this-to-a-secure-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_NAME="TechStore"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DESCRIPTION="Your one-stop shop for smartphones, computers, and electronics"

# Upload
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE="5242880"

# WhatsApp Business Cloud API (notifications de commandes)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
ADMIN_WHATSAPP_NUMBER=""
